FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8

# Base system + dev tools
RUN apt-get update && apt-get install -y \
    bash zsh git curl wget vim neovim tmux \
    openssh-client openssh-server \
    build-essential python3 python3-pip python3-venv \
    jq ripgrep fd-find htop tree unzip zip \
    locales ca-certificates gnupg \
    && locale-gen en_US.UTF-8 \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Node.js 20 LTS
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# AI CLI tools
RUN npm install -g \
    @anthropic-ai/claude-code \
    @openai/codex \
    && npm cache clean --force

# OpenCode (Go-based AI CLI)
RUN curl -fsSL https://opencode.ai/install.sh | bash 2>/dev/null || true

# Rust (for development)
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable --profile minimal
ENV PATH="/root/.cargo/bin:${PATH}"

# Create dev user with zsh as default shell
RUN useradd -m -s /bin/zsh -G sudo devuser \
    && echo "devuser ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# Setup SSH directory
RUN mkdir -p /home/devuser/.ssh && chmod 700 /home/devuser/.ssh \
    && chown -R devuser:devuser /home/devuser/.ssh

# Setup workspace
RUN mkdir -p /home/devuser/workspace && chown devuser:devuser /home/devuser/workspace

USER devuser
WORKDIR /home/devuser

# Rust for devuser
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable --profile minimal
ENV PATH="/home/devuser/.cargo/bin:${PATH}"

# Oh-my-zsh
RUN sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended

# Zsh config
RUN sed -i 's/plugins=(git)/plugins=(git docker node rust python ssh-agent)/' ~/.zshrc \
    && echo 'export PATH="$HOME/.cargo/bin:$HOME/.local/bin:$PATH"' >> ~/.zshrc \
    && echo 'export TERM=xterm-256color' >> ~/.zshrc

WORKDIR /home/devuser/workspace

CMD ["/bin/zsh"]
